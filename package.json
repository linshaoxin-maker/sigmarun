{
  "name": "sigmarun-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -b packages/storage packages/core packages/cli",
    "typecheck": "tsc -b packages/storage packages/core packages/cli --force"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
